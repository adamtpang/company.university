# PostHog analytics (client side). Leave unset to disable analytics.
# The provider is a no op when NEXT_PUBLIC_POSTHOG_KEY is empty, so the
# site builds and runs fine without a key. Copy this file to .env.local
# and fill in your real project values. Never commit a real key.

# Your PostHog project API key (starts with phc_)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key_here

# PostHog API host. US cloud default shown. Use https://eu.i.posthog.com for EU.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
